{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run vercel-build",
  "installCommand": "bun install",
  "devCommand": "bun run dev",
  "regions": ["sin1", "bom1", "fra1", "iad1"],
  "functions": {
    "src/app/api/chatbot/message/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/chatbot/init/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/chatbot/history/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/chatbot/suggestions/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/chatbot/feedback/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/admin/widget/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/admin/sessions/route.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/chatbot/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/api/chatbot/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Accept" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ]
}
